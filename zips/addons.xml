<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="plugin.program.smartbox.notification" version="1.0"
       name="Notifications" provider-name="SmartBox Entertainment">
  <requires>
  	<import addon="xbmc.python" version="2.1.0"/>
  	<import addon="script.module.addon.common" optional="true" />
  </requires>
  <extension point="xbmc.python.script" library="default.py">
    <provides>executable</provides>
  </extension>
  <extension point="xbmc.service" library="service.py" start="startup">
  </extension>
  <extension point="xbmc.addon.metadata">
  	<summary>SmartBox News</summary>
  	<description>Receive Important SmartBox Entertainment Notifications. Unsubscribe within Add-on Settings.</description>
  	<disclaimer>We take no responsibility for any problems this plugin might in any way, form, shape or size cause.</disclaimer>
  	<language>en</language>
  	<platform>all</platform>
  	<forum>https://www.facebook.com/groups/smartBoxnz/</forum>
  	<website>http://www.smartboxnz.co.nz/</website>
  	<source></source>
  	<email></email>
  </extension>
</addon>

<addon id="repository.smartboxnz" name="SmartBox Repository " version="1.0" provider-name="smartboxnz">
    <extension point="xbmc.addon.repository" name="SmartBox Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/smartboxnz/repository.smartboxnz/master/zips/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/smartboxnz/repository.smartboxnz/master/zips/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/smartboxnz/repository.smartboxnz/master/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>SmartBox Repository</summary>
        <description>SmartBox Entertainment Repository for SmartBox NZ system.</description>
        <disclaimer></disclaimer>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
</addons>
